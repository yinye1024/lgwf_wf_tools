      },
      "expected": {
        "workflow_id": "wf-prompt-upgrade",
        "must_read": ["workflows/wf-prompt-upgrade/AGENTS.md"],
        "required_text": [
          {
            "path": "workflows/wf-prompt-upgrade/AGENTS.md",
            "contains": "在用户 approve 后"
          }
        ]
      }
    },
    {
