WORKFLOW script_flow_e2e;
ENTRY script_flow_e2e_react;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  instruction_path "lgwf_e2e.script_flow.instructions.{node}";
  result_path "lgwf_e2e.script_flow.results.{node}";
}

REACT script_flow_e2e_react MAX 3
  SPEC "01_design/agents/spec.md"
  REASON CODEX
    PROMPT "01_design/agents/reason.md"
    CONTEXT workspace file ".lgwf/e2e_target_request.normalized.json"
    CONTEXT workspace file ".lgwf/e2e_workflow_graph.json"
    CONTEXT workspace file ".lgwf/e2e_coverage_matrix.json"
    TARGET_DIRS state.lgwf_e2e.target_dirs
    TARGET_FILES state.lgwf_e2e.target_files
    OUTPUT_JSON ".lgwf/e2e_script_flow_design.json"
    RESULT state.lgwf_e2e.script_flow_reason_result
  ACT CODEX
    PROMPT "02_generate/agents/act.md"
    CONTEXT workspace file ".lgwf/e2e_target_request.normalized.json"
    CONTEXT workspace file ".lgwf/e2e_workflow_graph.json"
    CONTEXT workspace file ".lgwf/e2e_coverage_matrix.json"
    CONTEXT workspace file ".lgwf/e2e_script_flow_design.json"
    TARGET_DIRS state.lgwf_e2e.target_dirs
    TARGET_FILES state.lgwf_e2e.target_files
    OUTPUT_JSON ".lgwf/e2e_script_flow_generation.json"
    RESULT state.lgwf_e2e.script_flow_act_result
  OBSERVE CODEX
    PROMPT "03_validate/agents/observe.md"
    CONTEXT workspace file ".lgwf/e2e_target_request.normalized.json"
    CONTEXT workspace file ".lgwf/e2e_coverage_matrix.json"
    CONTEXT workspace file ".lgwf/e2e_script_flow_design.json"
    CONTEXT workspace file ".lgwf/e2e_script_flow_generation.json"
    TARGET_DIRS state.lgwf_e2e.target_dirs
    TARGET_FILES state.lgwf_e2e.target_files
    OUTPUT_JSON ".lgwf/e2e_script_flow_observe.json"
    RESULT state.lgwf_e2e.script_flow_observe_result
  DECIDE PY
    SCRIPT "04_repair/scripts/decide_script_flow.py"
    RESULT state.lgwf_e2e.script_flow_decide_result
    UPDATES_STATE;
