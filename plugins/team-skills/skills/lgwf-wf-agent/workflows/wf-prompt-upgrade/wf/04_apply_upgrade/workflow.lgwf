WORKFLOW prompt_upgrade_apply_upgrade;
ENTRY apply_prompt_upgrade;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  instruction_path "lgwf_wf_prompt_upgrade.instructions.{node}";
  result_path "lgwf_wf_prompt_upgrade.results.{node}";
}

REACT apply_prompt_upgrade MAX 3
  SPEC "agents/spec.md"

  REASON CODEX
    PROMPT "agents/reason.md"
    CONTEXT workspace file ".lgwf/prompt_upgrade_target.json"
    CONTEXT workspace file ".lgwf/prompt_upgrade/inventory.json"
    CONTEXT workspace file ".lgwf/prompt_upgrade/proposal.json"
    CONTEXT workspace file ".lgwf/prompt_upgrade/decision.json"
    CONTEXT workspace file ".lgwf/prompt_upgrade/react_history.json"
    TARGET_DIRS state.lgwf_wf_prompt_upgrade.target_dirs
    OUTPUT_JSON ".lgwf/prompt_upgrade/apply_plan.json" AS_FILE
    RESULT state.lgwf_wf_prompt_upgrade.apply_reason_result

  ACT WORKFLOW apply_prompt_upgrade_once
    WORKFLOW "act_apply_prompt_upgrade/workflow.lgwf"
    RESULT state.lgwf_wf_prompt_upgrade.apply_act_result

  OBSERVE CODEX
    PROMPT "agents/observe.md"
    CONTEXT workspace file ".lgwf/prompt_upgrade/inventory.json"
    CONTEXT workspace file ".lgwf/prompt_upgrade/proposal.json"
    CONTEXT workspace file ".lgwf/prompt_upgrade/decision.json"
    CONTEXT workspace file ".lgwf/prompt_upgrade/apply_plan.json"
    CONTEXT workspace file ".lgwf/prompt_upgrade/react_history.json"
    TARGET_DIRS state.lgwf_wf_prompt_upgrade.target_dirs
    OUTPUT_JSON ".lgwf/prompt_upgrade/apply_review.json"
    RESULT state.lgwf_wf_prompt_upgrade.apply_observe_result

  DECIDE PY
    SCRIPT "scripts/decide_prompt_upgrade_apply.py"
    TIMEOUT 60
    RESULT state.lgwf_wf_prompt_upgrade.apply_decide_result
    UPDATES_STATE;
