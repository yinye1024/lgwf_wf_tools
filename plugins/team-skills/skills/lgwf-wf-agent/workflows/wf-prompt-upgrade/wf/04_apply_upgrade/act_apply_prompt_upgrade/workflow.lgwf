WORKFLOW prompt_upgrade_apply_prompt_upgrade_once;
ENTRY validate_apply_plan;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  instruction_path "lgwf_wf_prompt_upgrade.instructions.{node}";
  result_path "lgwf_wf_prompt_upgrade.results.{node}";
}

PY validate_apply_plan
  SCRIPT "scripts/validate_apply_plan.py"
  TIMEOUT 30
  RESULT state.lgwf_wf_prompt_upgrade.validate_apply_plan_result
  UPDATES_STATE;

CODEX apply_prompt_upgrade
  PROMPT "agents/act.md"
  CONTEXT workspace file ".lgwf/prompt_upgrade_target.json"
  CONTEXT workspace file ".lgwf/prompt_upgrade/apply_plan.json"
  CONTEXT workspace file ".lgwf/prompt_upgrade/apply_plan_validation.json"
  TARGET_DIRS state.lgwf_wf_prompt_upgrade.target_dirs
  RESULT state.lgwf_wf_prompt_upgrade.apply_act_result;

FLOW validate_apply_plan THEN apply_prompt_upgrade;
