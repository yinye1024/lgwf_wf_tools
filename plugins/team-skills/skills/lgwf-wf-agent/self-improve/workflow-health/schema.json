{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "lgwf-wf-agent workflow health inventory",
  "type": "object",
  "required": ["version", "workflows"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "integer", "const": 1},
    "workflows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "expected_role", "audit_command", "test_command"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "expected_role": {"type": "string"},
          "audit_command": {"type": "string"},
          "test_command": {"type": "string"},
          "semantic_requirements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "description", "any_contains"],
              "additionalProperties": false,
              "properties": {
                "id": {"type": "string"},
                "description": {"type": "string"},
                "any_contains": {
                  "type": "array",
                  "items": {"type": "string"},
                  "minItems": 1
                }
              }
            }
          },
          "known_blockers": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
