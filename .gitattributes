# 文本文件统一使用 LF，避免 Windows 上 CRLF/LF 混合导致 Codex 反复改动。
* text=auto eol=lf

# 常见源码、配置、文档格式显式固定为 LF。
*.bat text eol=lf
*.cmd text eol=lf
*.css text eol=lf
*.html text eol=lf
*.ini text eol=lf
*.js text eol=lf
*.json text eol=lf
*.lgwf text eol=lf
*.md text eol=lf
*.ps1 text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# 常见二进制文件不做换行转换。
*.7z binary
*.docx binary
*.gif binary
*.gz binary
*.ico binary
*.jpeg binary
*.jpg binary
*.pdf binary
*.png binary
*.pptx binary
*.tar binary
*.webp binary
*.whl binary
*.xls binary
*.xlsx binary
*.zip binary
