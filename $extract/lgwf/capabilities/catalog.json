    {
      "name": "subgraph.react",
      "kind": "subgraph",
      "description": "Run a fixed reason, act, observe, decide loop pattern.",
      "config_schema": {
        "max_steps": {"type": "integer", "default": 5},
        "spec_ref": {
          "type": "resource_ref",
          "required": false,
          "description": "Optional governing spec injected into reason, act, and observe. It is not passed to decide."
        },
        "reason": {"type": "node", "required": true},
        "act": {"type": "node", "required": true},
        "observe": {"type": "node", "required": true},
        "decide": {"type": "node", "required": true},
        "on_max": {
          "type": "object",
          "required": false,
          "description": "Optional human approval prompt when decide requests continue at the current ReAct max-step limit.",
          "fields": {
            "type": {"type": "string", "enum": ["human_approval"], "required": true},
            "prompt": {"type": "string", "required": true},
            "context_path": {"type": "string", "required": true},
            "approved_value_path": {"type": "string", "required": true},
            "result_path": {"type": "string", "required": true},
            "status_path": {"type": "string", "required": true},
            "extra_max_steps": {"type": "integer", "required": true},
            "timeout_seconds": {"type": ["number", "null"], "required": false},
            "poll_interval_seconds": {"type": "number", "required": false, "default": 1}
          }
        }
      },
      "reads": ["next", "slots.reads", "config.on_max.context_path"],
      "writes": ["next", "slots.writes", "config.on_max.approved_value_path", "config.on_max.result_path", "config.on_max.status_path"],
      "side_effects": ["depends_on_slots", "may_write_human_request", "waits_for_human_response"],
      "examples": [
        {
          "id": "agent",
          "capability": "subgraph.react",
          "config": {
            "max_steps": 5,
            "reason": {"capability": "exec.echo"},
            "act": {"capability": "exec.echo"},
            "observe": {"capability": "exec.echo"},
            "decide": {"capability": "flow.assign", "config": {"assignments": {"next": "exit"}}}
          }
        }
      ]
    },
