{"kind":"textbox","id":"sh/bm58z25k","slide":9,"text":"AGENT_LOOP build_stock_brief MAX_ITERATIONS 5\n  ARTIFACTS \".lgwf/loops/build_stock_brief\"\n  STATUS state.stock.loop_status\n  REPORT state.stock.loop_report\n  ON_MAX wait_human ON_ERROR wait_human {\n  OBSERVE PY collect_stock_context\n    SCRIPT \"scripts/collect_stock_context.py\"\n    RESULT state.stock.observe;\n  DIAGNOSE CODEX find_research_gaps\n    PROMPT_REF \"agents/diagnose.md\"\n    RESULT state.stock.gaps;\n  PLAN CODEX plan_brief_updates\n    PROMPT_REF \"agents/plan.md\"\n    RESULT state.stock.plan;\n  ACT CODEX draft_stock_brief\n    PROMPT_REF \"agents/apply.md\"\n    RESULT state.stock.brief;\n  VERIFY WORKFLOW verify_stock_brief\n    WORKFLOW \"verify_stock_brief.lgwf\"\n    RESULT state.stock.verify;\n  DECIDE PY decide_stock_loop\n    SCRIPT \"scripts/decide.py\"\n    RESULT state.stock.decision;\n};","textPreview":"AGENT_LOOP build_stock_brief MAX_ITERATIONS 5 |   ARTIFACTS \".lgwf/loops/build_stock_brief\" |   STATUS state.stock.loop_status |   REPORT...","textChars":801,"textLines":24,"bbox":[668,204,499,423]}
