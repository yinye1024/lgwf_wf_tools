WORKFLOW entry_scope_resolution;
ENTRY normalize_runtime_request;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 180;
  result_path "repo_context_pack.entry_scope_resolution.{node}";
}

PY normalize_runtime_request
  SCRIPT "scripts/run.py"
  TIMEOUT 120
  RESULT state.repo_context_pack.request
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/repo_context_pack_request.json";
  };

FLOW normalize_runtime_request;
