{
  "module_name": "repo-context-pack",
  "workflow_root": "wf",
  "output_root": "request.output_dir",
  "encoding": "UTF-8 no BOM",
  "runtime_artifacts": [
    ".lgwf/repo_context_pack_request.json",
    ".lgwf/context_inventory.json",
    ".lgwf/context_pack_generation.json",
    ".lgwf/repo_context_pack_summary.json",
    "reports/repo-context-pack/report.md"
  ],
  "final_outputs": [
    ".lgwf/repo_context_pack_summary.json",
    "reports/repo-context-pack/report.md"
  ],
  "artifacts": [
    {
      "id": "repo_context_pack",
      "path": "repo_context_pack.md",
      "required": true,
      "format": "markdown",
      "producer": "context_pack_rendering"
    },
    {
      "id": "agent_handoff",
      "path": "agent_handoff.md",
      "required": true,
      "format": "markdown",
      "producer": "context_pack_rendering"
    },
    {
      "id": "module_map",
      "path": "module_map.json",
      "required": true,
      "format": "json",
      "producer": "context_pack_rendering"
    },
    {
      "id": "command_inventory",
      "path": "command_inventory.json",
      "required": true,
      "format": "json",
      "producer": "context_pack_rendering"
    },
    {
      "id": "risk_register",
      "path": "risk_register.md",
      "required": true,
      "format": "markdown",
      "producer": "context_pack_rendering"
    },
    {
      "id": "read_order",
      "path": "read_order.md",
      "required": true,
      "format": "markdown",
      "producer": "context_pack_rendering"
    },
    {
      "id": "summary",
      "path": "summary.json",
      "required": true,
      "format": "json",
      "producer": "workflow_summary_handoff"
    }
  ],
  "constraints": [
    "不得写入 request.output_dir 之外的上下文包产物。",
    "不得修改 request.target_dir 内源码。",
    "Markdown 与 JSON 产物统一使用 UTF-8 no BOM。"
  ]
}
