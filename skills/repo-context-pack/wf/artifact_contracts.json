{
  "contract_version": 1,
  "workflow_id": "repo-context-pack",
  "package_profile": "internal_workflow_package",
  "description": "定义 repo-context-pack 四阶段 handoff JSON 与最终输出约束。",
  "shared_rules": {
    "encoding": "UTF-8 no BOM",
    "target_repository_mode": "read_only",
    "path_policy": {
      "relative_only": true,
      "allow_parent_reference": false,
      "allow_absolute_path": false,
      "allow_url": false
    },
    "execution_policy": [
      "deterministic_python_only",
      "no_runtime_codex_prompt_scan_target_repository"
    ]
  },
  "handoff_sequence": [
    {
      "order": 1,
      "artifact_id": "repo_context_pack_request",
      "filename": "repo_context_pack_request.json",
      "producer_stage": "01_entry_scope_resolution",
      "consumer_stage": "02_target_context_inventory",
      "required_fields": [
        "target_root",
        "resolved_output_dir",
        "normalized_targets",
        "read_only_boundary"
      ],
      "description": "规范化后的启动请求，包含默认输出目录和路径边界结论。"
    },
    {
      "order": 2,
      "artifact_id": "context_inventory",
      "filename": "context_inventory.json",
      "producer_stage": "02_target_context_inventory",
      "consumer_stage": "03_context_pack_rendering",
      "required_fields": [
        "inventory",
        "entrypoints",
        "module_map",
        "commands",
        "risk_markers",
        "truncation"
      ],
      "description": "目标仓库盘点结果，包含入口、模块映射、命令线索、风险标记与截断信息。"
    },
    {
      "order": 3,
      "artifact_id": "context_pack_generation",
      "filename": "context_pack_generation.json",
      "producer_stage": "03_context_pack_rendering",
      "consumer_stage": "04_workflow_summary_handoff",
      "required_fields": [
        "artifact_plan",
        "rendered_artifacts",
        "artifact_index",
        "warnings"
      ],
      "description": "渲染阶段生成的产物计划、实际文件清单与告警摘要。"
    },
    {
      "order": 4,
      "artifact_id": "repo_context_pack_summary",
      "filename": "repo_context_pack_summary.json",
      "producer_stage": "04_workflow_summary_handoff",
      "consumer_stage": "handoff",
      "required_fields": [
        "status",
        "rendered_artifacts",
        "coverage",
        "risks",
        "handoff_summary"
      ],
      "description": "最终摘要，供调用方或下游 workflow 消费。"
    }
  ],
  "rendered_outputs": {
    "base_dir_source": "request.output_dir",
    "required_summary_file": "repo_context_pack_summary.json",
    "expected_categories": [
      "markdown",
      "json"
    ]
  },
  "validation_focus": [
    "四阶段 handoff 文件名与顺序固定",
    "所有路径均为目标 package 内相对路径",
    "渲染过程坚持确定性 Python，不依赖运行期 Codex prompt 扫描目标仓库"
  ]
}
