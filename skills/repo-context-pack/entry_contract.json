{
  "contract_version": 1,
  "workflow_id": "repo-context-pack",
  "workflow_name": "repo-context-pack",
  "kind": "lgwf_workflow_package",
  "package_profile": "internal_workflow_package",
  "description": "对目标仓库执行只读、确定性 Python 扫描，生成可复用的仓库上下文包。",
  "entrypoint": {
    "workflow_path": "wf/workflow.lgwf",
    "artifacts_contract_path": "wf/artifact_contracts.json"
  },
  "input_mode": {
    "type": "json_object",
    "root_field": "request",
    "description": "通过结构化 request 启动，不依赖运行期 Codex prompt 扫描目标仓库。"
  },
  "required_fields": [
    "request.target_root"
  ],
  "request_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "target_root"
    ],
    "properties": {
      "target_root": {
        "type": "string",
        "description": "需要扫描的目标仓库或目录根路径，必须是相对调用方 workspace root 的相对路径。"
      },
      "target_dirs": {
        "type": "array",
        "description": "可选，只读扫描的重点目录列表；每一项必须是目标仓库内相对路径。",
        "items": {
          "type": "string"
        },
        "default": []
      },
      "target_files": {
        "type": "array",
        "description": "可选，只读扫描的重点文件列表；每一项必须是目标仓库内相对路径。",
        "items": {
          "type": "string"
        },
        "default": []
      },
      "output_dir": {
        "type": "string",
        "description": "可选，渲染产物输出目录；若缺失，由第一阶段按契约推导默认目录。"
      },
      "consumer_goal": {
        "type": "string",
        "description": "可选，说明上下文包服务的下游目标，例如代码评审、迁移分析或修复规划。"
      },
      "constraints": {
        "type": "array",
        "description": "可选，附加的范围、忽略项或输出要求。",
        "items": {
          "type": "string"
        },
        "default": []
      }
    }
  },
  "path_policy": {
    "relative_only": true,
    "allow_parent_reference": false,
    "allow_absolute_path": false,
    "allow_url": false
  },
  "state_boundary": {
    "work_dir_state_root": "ws/.lgwf",
    "package_state_allowed": false,
    "target_repository_mode": "read_only"
  },
  "artifacts": {
    "handoff_sequence": [
      "repo_context_pack_request.json",
      "context_inventory.json",
      "context_pack_generation.json",
      "repo_context_pack_summary.json"
    ],
    "summary_artifact": "repo_context_pack_summary.json"
  },
  "auto_human_policy": {
    "mode": "not_required",
    "reason": "当前四个阶段均为确定性处理与汇总，不设计人工审批节点。"
  },
  "non_goals": [
    "不执行目标仓库中发现的命令或修复步骤",
    "不在运行期使用 Codex prompt 扫描目标仓库",
    "不向目标 package 根目录写入 .lgwf"
  ]
}
