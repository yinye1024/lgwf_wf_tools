      "workflow_lgwf": "workflows/wf-fix/wf/workflow.lgwf",
      "work_dir": "workflows/wf-fix/ws",
      "agents_md": "workflows/wf-fix/AGENTS.md"
    },
    {
      "id": "wf-audit-fix",
