      "workflow_lgwf": "workflows/wf-audit-fix/wf/workflow.lgwf",
      "work_dir": "workflows/wf-audit-fix/ws",
      "agents_md": "workflows/wf-audit-fix/AGENTS.md"
    },
    {
      "id": "wf-create",
      "kind": "lgwf",
