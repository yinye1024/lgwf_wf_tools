{
  "version": 1,
  "cases": [
    {
      "id": "route-runtime-failure-to-wf-fix",
      "category": "routing",
      "input": {
        "user_request": "这个 workflow 跑失败了，帮我修好",
        "context": ["存在 workflow.lgwf", "存在失败 run record"]
      },
      "expected": {
        "workflow_id": "wf-fix",
        "must_read": ["registry.json", "workflows/wf-fix/AGENTS.md"],
        "must_not_start": ["wf-prompt-upgrade", "e2e-test-generator"]
      }
    },
    {
      "id": "route-prompt-acceptance-to-wf-prompt-fix",
      "category": "routing",
      "input": {
        "user_request": "检查这个 workflow 引用的 prompt 是否合格，基础问题可以修",
        "context": ["目标 workflow DSL 可解析", "不要求真实运行目标 workflow"]
      },
      "expected": {
        "workflow_id": "wf-prompt-fix",
        "must_read": ["registry.json", "workflows/wf-prompt-fix/AGENTS.md"],
        "must_not_start": ["wf-fix"]
      }
    },
    {
      "id": "route-delivery-quality-reroutes-by-evidence",
      "category": "routing",
      "input": {
        "user_request": "这个 workflow 要交付，帮我把质量做完整",
        "context": ["已有 workflow.lgwf", "允许分阶段确认", "facade 不默认组装多个 workflow"]
      },
      "expected": {
        "workflow_id": "wf-prompt-fix",
        "must_read": ["AGENTS.md", "registry.json"],
        "required_text": [
          {
            "path": "docs/workflow-routing.md",
            "contains": "不默认组装多个 workflow"
          },
          {
            "path": "docs/workflow-routing.md",
            "contains": "基于结果证据决定是否重新路由"
          }
        ]
      }
    },
    {
      "id": "route-self-improve-natural-language",
      "category": "routing",
      "input": {
        "user_request": "[$lgwf-wf-tools] 自我优化：这个 agent 交互体验很差，把这次问题沉淀成 case 并给改进方案",
        "context": ["用户明确要求 self-improve", "问题属于 agent 路由和主动沟通体验"]
      },
      "expected": {
        "must_read": ["AGENTS.md", "self-improve/manifest.json"],
        "required_text": [
          {
            "path": "SKILL.md",
            "contains": "/lgwf-wf-tools self-improve"
          },
          {
            "path": "SKILL.md",
            "contains": "/lgwf-wf-tools 自我优化"
          },
          {
            "path": "AGENTS.md",
            "contains": "docs/self-improve.md"
          },
          {
            "path": "docs/self-improve.md",
            "contains": "先归类问题、列出可执行的 self-improve 路径"
          }
        ]
      }
    },
    {
      "id": "route-new-workflow-creation-to-wf-create",
      "category": "routing",
      "input": {
        "user_request": "我只有一个原始想法，帮我创建一个新的 LGWF workflow 初稿",
        "context": ["用户调用 lgwf-wf-tools", "目标是从零创建 workflow", "需要分阶段确认需求、业务流和步骤设计"]
      },
      "expected": {
        "workflow_id": "wf-create",
        "must_read": ["AGENTS.md", "registry.json", "workflows/wf-create/AGENTS.md"],
        "required_text": [
          {
            "path": "docs/workflow-routing.md",
            "contains": "目标是从原始意图创建新的 LGWF workflow 初稿"
          },
          {
            "path": "docs/workflow-routing.md",
            "contains": "使用 `wf-create`"
          },
          {
            "path": "registry.json",
            "contains": "\"id\": \"wf-create\""
          }
        ]
      }
    },
    {
      "id": "route-workflow-authoring-preflight-lists-workflows",
      "category": "routing",
      "input": {
        "user_request": "现在我有一个新建的工作流 lgwf-wf-create，帮我把这个工作流完善起来",
        "context": ["用户调用 lgwf-wf-tools", "目标是复杂 workflow package 完善", "需要选择内部 workflow"]
      },
      "expected": {
        "workflow_id": "plan",
        "must_read": ["AGENTS.md", "registry.json", "workflows/plan/AGENTS.md"],
        "required_text": [
          {
            "path": "AGENTS.md",
            "contains": "场景路由表"
          },
          {
            "path": "AGENTS.md",
            "contains": "docs/workflow-routing.md"
          },
          {
            "path": "AGENTS.md",
            "contains": "docs/facade-dispatch.md"
          }
        ]
      }
    },
    {
      "id": "route-ambiguous-optimize-fix-requires-proposal-first",
      "category": "routing",
      "input": {
        "user_request": "优化 修复 D:/repo/skills/lgwf-wf-tools/workflows/wf-create 这个工作流",
        "context": ["目标 workflow authoring audit passed", "用户没有明确授权立即运行或自动修复", "请求同时包含优化和修复"]
      },
      "expected": {
        "workflow_id": "wf-prompt-fix",
        "must_read": ["AGENTS.md", "registry.json", "workflows/wf-prompt-fix/AGENTS.md"],
        "must_not_start": ["wf-fix"],
        "required_text": [
          {
            "path": "docs/proposal-gate.md",
            "contains": "模糊请求 proposal gate"
          },
          {
            "path": "docs/proposal-gate.md",
            "contains": "proposal 前禁止改文件"
          },
          {
            "path": "docs/proposal-gate.md",
            "contains": "模糊的“优化/修复”"
          },
          {
            "path": "docs/workflow-routing.md",
            "contains": "不默认连续执行质量链路"
          },
          {
            "path": "docs/workflow-routing.md",
            "contains": "再重新列出候选、说明理由并重新路由"
          }
        ]
      }
    },
    {
      "id": "route-ambiguous-modify-goal-requires-proposal-gate",
      "category": "routing",
      "input": {
        "user_request": "修复优化 D:/repo/skills/lgwf-wf-tools/workflows/wf-create",
        "context": ["用户给出目标 package 路径", "没有明确授权直接修改", "没有真实失败 run 证据"]
      },
      "expected": {
        "must_read": ["AGENTS.md", "registry.json"],
        "must_not_start": ["wf-fix", "wf-prompt-fix", "wf-prompt-upgrade", "e2e-test-generator", "plan", "apply_patch"],
        "required_text": [
          {
            "path": "docs/proposal-gate.md",
            "contains": "ambiguous_modify_goal"
          },
          {
            "path": "docs/proposal-gate.md",
            "contains": "除非用户明确说“直接修改”"
          },
          {
            "path": "docs/proposal-gate.md",
            "contains": "禁止改文件"
          },
          {
            "path": "docs/proposal-gate.md",
            "contains": "禁止启动任何内部 workflow"
          },
          {
            "path": "docs/proposal-gate.md",
            "contains": "目标、发现依据、候选路由、修改范围"
          }
        ]
      }
    }
  ]
}
