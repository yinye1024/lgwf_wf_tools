WORKFLOW static_approval_router;
ENTRY intake_request;

DEFAULTS {
  ref_root workflow ".";
}

STEP intake_request
  PROMPT "agents/intake_request.md"
  CONTEXT workspace file "artifacts/request_input.txt";

STEP classify_risk
  PROMPT "agents/classify_risk.md";

STEP decide_route
  PROMPT "agents/decide_route.md";

FLOW intake_request
  THEN classify_risk
  THEN decide_route;
