{
  "id": "wf-convert",
  "kind": "lgwf",
  "version": 1,
  "workflow_lgwf": "workflows/wf-convert/wf/workflow.lgwf",
  "work_dir": "workflows/wf-convert/ws",
  "input_mode": "input_json_required",
  "input_schema": {
    "type": "object",
    "required": ["prompt_convert_target"],
    "properties": {
      "prompt_convert_target": {
        "type": "object",
        "required": ["target_dir"],
        "properties": {
          "target_dir": {"type": "string"},
          "entry_files": {"type": "array"},
          "target_workflow_name": {"type": "string"},
          "target_package_root": {"type": "string"}
        }
      },
      "request": {"type": "object"}
    },
    "example": {
      "prompt_convert_target": {
        "target_dir": "D:/example/prompt-workflow",
        "entry_files": ["README.md"],
        "target_workflow_name": "example-workflow",
        "target_package_root": "skills/example-workflow"
      }
    }
  },
  "input_file_policy": "Use UTF-8 no BOM --input-json-file for prompt_convert_target.",
  "auto_human_policy": "conditional",
  "target_scope": {
    "fields": ["prompt_convert_target.target_dir", "prompt_convert_target.target_package_root"],
    "write_scope": "wf-convert only prepares and confirms the wf-create-fast input, then hands off to the main agent to start wf-create-fast."
  },
  "state_boundary": {
    "work_dir": "workflows/wf-convert/ws",
    "runtime_state": ".lgwf/",
    "target_writes": "target_package_root approved by conversion plan"
  },
  "outputs": {
    "wf_create_fast_payload": ".lgwf/wf_create_fast_payload.json",
    "wf_create_fast_input": ".lgwf/wf_create_fast_input_for_wf_create_fast.json",
    "handoff": ".lgwf/wf_create_fast_handoff.json"
  },
  "resume_policy": "Use the facade continue/resume/rerun flow for the fixed work_dir."
}
