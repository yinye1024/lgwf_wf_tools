{
  "version": 1,
  "cases": [
    {
      "id": "monitoring-must-read-vendor-agent-host-guide",
      "category": "monitoring",
      "input": {
        "user_request": "运行这个内部 workflow 并持续跟踪",
        "context": ["workflow 可能包含 approval 或长时间 Codex 节点"]
      },
      "expected": {
        "must_read": [
          "vendor/lgwf-client-assist/AGENTS.md",
          "vendor/lgwf-client-assist/references/agent-host-assist/guide.md",
          "vendor/lgwf-client-assist/references/agent-host-assist/cli-agent-loop.md",
          "vendor/lgwf-client-assist/references/workflow-usage.md"
        ],
        "required_text": [
          {
            "path": "docs/facade-dispatch.md",
            "contains": "waiting_human` 不是完成状态"
          }
        ]
      }
    },
    {
      "id": "approval-distinguishes-human-approval-and-agent-loop-wait",
      "category": "approval",
      "input": {
        "user_request": "workflow 停在 waiting_human，继续处理",
        "context": ["可能是 flow.human_approval", "也可能是 AGENT_LOOP 控制状态"]
      },
      "expected": {
        "must_read": ["vendor/lgwf-client-assist/references/agent-host-assist/cli-agent-loop.md"],
        "required_text": [
          {
            "path": "docs/facade-dispatch.md",
            "contains": "AGENT_LOOP` 控制状态但没有 human request"
          }
        ]
      }
    },
    {
      "id": "codex-token-zero-before-timeout-is-not-failure",
      "category": "monitoring",
      "input": {
        "user_request": "Codex 节点 token-status 长时间是 0，要不要判失败？",
        "context": [
          "current_capability=exec.codex_prompt",
          "token_usage.total_tokens=0",
          "health.seconds_since_update 持续增大",
          "后台 pid 仍存在",
          "节点未达到 timeout_seconds"
        ]
      },
      "expected": {
        "required_text": [
          {
            "path": "workflows/01-share/lgwf-monitor.md",
            "contains": "节点未达到自身 `timeout_seconds` 前"
          },
          {
            "path": "docs/facade-dispatch.md",
            "contains": "不能单独判定失败"
          }
        ],
        "forbidden_actions": [
          "stop",
          "rerun",
          "skip",
          "manual_artifact_write"
        ],
        "required_behavior": "只能提醒用户疑似无进展并展示证据，等待用户决定。"
      }
    }
  ]
}
