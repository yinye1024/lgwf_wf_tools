{
  "version": 1,
  "cases": [
    {
      "id": "release-preserves-local-self-improve-history",
      "category": "release",
      "input": {
        "user_request": "发布 lgwf-wf-tools 时不能覆盖自我提升历史",
        "context": ["发布包会覆盖 skill 源文件", ".local 保存运行期状态"]
      },
      "expected": {
        "required_text": [
          {
            "path": "docs/maintenance.md",
            "contains": "发布包不得覆盖或删除 `.local/self-improve/`"
          },
          {
            "path": ".gitignore",
            "contains": ".local/"
          }
        ],
        "changed_file_triggers": [
          "SKILL.md",
          "AGENTS.md",
          "registry.json",
          "workflows/wf-fix/AGENTS.md",
          "vendor/lgwf-client-assist/.lgwf-client-assist-vendor.json"
        ]
      }
    },
    {
      "id": "self-improve-scripts-do-not-apply-changes",
      "category": "release",
      "input": {
        "user_request": "self-improve 只能生成记录和提案，不能自动改发布文件",
        "context": ["第一版和第二版都保持人工 approval 边界"]
      },
      "expected": {
        "required_text": [
          {
            "path": "docs/self-improve.md",
            "contains": "self-improve 脚本只生成记录、报告和 proposal"
          },
          {
            "path": "workflows/self-improve/AGENTS.md",
            "contains": "不自动修改 `AGENTS.md`、`registry.json` 或 workflow 文件"
          }
        ]
      }
    }
  ]
}
