WORKFLOW collect_targets;
ENTRY FLOW main;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 300;
  instruction_path "lgwf_wf_dsl_upgrade.instructions.{node}";
  result_path "lgwf_wf_dsl_upgrade.results.{node}";
}

PY build_target_manifest
  SCRIPT "scripts/build_target_manifest.py"
  TIMEOUT 120
  RESULT state.lgwf_wf_dsl_upgrade.build_target_manifest_result
  UPDATES_STATE;

FLOW main
  START build_target_manifest;
