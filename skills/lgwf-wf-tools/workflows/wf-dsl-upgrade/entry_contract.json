{
  "id": "wf-dsl-upgrade",
  "kind": "lgwf",
  "version": 2,
  "workflow_lgwf": "workflows/wf-dsl-upgrade/wf/workflow.lgwf",
  "work_dir": "workflows/wf-dsl-upgrade/ws",
  "input_mode": "input_json_required",
  "input_schema": {
    "type": "object",
    "required": [
      "dsl_upgrade_target"
    ],
    "properties": {
      "dsl_upgrade_target": {
        "type": "object",
        "required": [
          "target_paths"
        ],
        "properties": {
          "target_paths": {
            "type": "array",
            "description": "显式授权的目标路径，可以是 .lgwf 文件，也可以是需要递归扫描 .lgwf 文件的目录。",
            "items": {
              "type": "string"
            }
          },
          "mode": {
            "type": "string",
            "enum": [
              "dry_run",
              "apply"
            ]
          },
          "allowed_dirs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scope_mode": {
            "type": "string",
            "enum": [
              "explicit",
              "registry"
            ]
          },
          "max_targets": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "request": {
        "type": "object"
      }
    },
    "example": {
      "dsl_upgrade_target": {
        "target_paths": [
          "D:/example"
        ],
        "mode": "dry_run",
        "allowed_dirs": [
          "D:/example"
        ],
        "scope_mode": "explicit",
        "max_targets": 8
      }
    }
  },
  "input_file_policy": "Use UTF-8 no BOM --input-json-file for dsl_upgrade_target.",
  "auto_human_policy": "conditional",
  "target_scope": {
    "fields": [
      "dsl_upgrade_target.target_paths",
      "dsl_upgrade_target.allowed_dirs"
    ],
    "write_scope": "Only the current FOREACH item target file when mode=apply, scope approval=approve, and the file is manifest-authorized under allowed_dirs."
  },
  "state_boundary": {
    "work_dir": "workflows/wf-dsl-upgrade/ws",
    "runtime_state": ".lgwf/",
    "target_writes": "Only state.wf_dsl_upgrade.current_target.path exposed through TARGET_FILES for the current FOREACH item."
  },
  "outputs": {
    "summary": ".lgwf/result_summary.json",
    "handoff": "",
    "reports": [
      "reports/wf-dsl-upgrade/report.md"
    ],
    "scope_confirmation": ".lgwf/scope_confirmation_context.json",
    "scope_approval": ".lgwf/scope_approval.json",
    "foreach_results_state": "state.wf_dsl_upgrade.target_results"
  },
  "resume_policy": "Use the facade continue/resume/rerun flow for the fixed work_dir. FOREACH resumes completed items by item index and items hash when runtime supports subgraph.foreach."
}
