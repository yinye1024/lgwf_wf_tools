WORKFLOW repair_target_agent_loop;
ENTRY run_target_workflow;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  result_path "lgwf_wf_fix.results.{node}";
}

PY run_target_workflow
  SCRIPT "03_run_target/scripts/run_target_workflow.py"
  TIMEOUT 120
  RESULT state.lgwf_wf_fix.run_target_result
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/self_fix_target.json";
    READ workspace file ".lgwf/target_workflow_input.json";
  };

PY observe_target_run
  SCRIPT "04_observe_target/scripts/observe_target_run.py"
  TIMEOUT 900
  RESULT state.lgwf_wf_fix.observe_target_result
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/self_fix_target.json";
  };

APPROVAL proxy_target_approval
  PROMPT_REF "04_observe_target/proxy_target_approval.md"
  READ state.lgwf_wf_fix.target_approval_context
  WRITE state.lgwf_wf_fix.target_approval_decision
  RESULT state.lgwf_wf_fix.target_approval_decision_result
  PERSIST ".lgwf/target_approval_decision.json"
  POLL 1;

PY submit_target_approval
  SCRIPT "04_observe_target/scripts/submit_target_approval.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_fix.submit_target_approval_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/target_approval_decision.json";
  };

PY route_after_observe
  SCRIPT "06_route/scripts/route_after_observe.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_fix.route_result
  UPDATES_STATE
  CONTRACT {
  };

PY prepare_repair_agent_loop
  SCRIPT "05_fix_target/scripts/prepare_repair_agent_loop.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_fix.prepare_repair_agent_loop_result
  UPDATES_STATE
  CONTRACT {
  };

AGENT_LOOP repair_target MAX_ITERATIONS 5 ARTIFACTS ".lgwf/loops/repair_target" STATUS state.lgwf_wf_fix.repair_target_loop_status REPORT state.lgwf_wf_fix.repair_target_loop_report TOKEN_MAX 1000000 ON_MAX wait_human ON_ERROR wait_human {
  GOAL "修复目标 workflow，使其通过静态验收并在下一轮运行中满足输出契约。"
  CONTEXT workspace file ".lgwf/self_fix_request.json"
  CONTEXT workspace file ".lgwf/self_fix_target.json"
  CONTEXT workspace file ".lgwf/target_workflow_input.json"
  CONTEXT workspace file ".lgwf/target_repair/current/run.json"
  CONTEXT workspace file ".lgwf/target_repair/current/observation.json"
  CONTEXT workspace file ".lgwf/target_repair/current/workspace.json"
  CONTRACT {
    WRITE workspace file ".lgwf/loops/repair_target/report.json";
  };

  OBSERVE PY observe_repair_context
    SCRIPT "05_fix_target/scripts/observe_repair_context.py"
    TIMEOUT 60
    RESULT state.lgwf_wf_fix.target_repair_observe_result
    UPDATES_STATE
    CONTRACT {
    };
  DIAGNOSE CODEX diagnose_target_failure
    PROMPT_REF "05_fix_target/agents/diagnose_target_failure.md"
    CONTEXT workspace file ".lgwf/target_repair/current/observation.json"
    OUTPUT_JSON ".lgwf/target_repair/current/diagnosis.json" AS_FILE
    RESULT state.lgwf_wf_fix.diagnose_target_result
    CONTRACT {
      READ workspace file ".lgwf/self_fix_request.json";
      READ workspace file ".lgwf/self_fix_target.json";
      READ workspace file ".lgwf/target_repair/current/apply.json";
      READ workspace file ".lgwf/target_repair/current/observation.json";
      READ workspace file ".lgwf/target_repair/current/plan.json";
      READ workspace file ".lgwf/target_repair/current/workspace.json";
      READ workspace file ".lgwf/target_workflow_input.json";
    };
  PLAN CODEX propose_repair_plan
    PROMPT_REF "05_fix_target/agents/propose_repair_plan.md"
    CONTEXT workspace file ".lgwf/target_repair/current/observation.json"
    CONTEXT workspace file ".lgwf/target_repair/current/diagnosis.json"
    OUTPUT_JSON ".lgwf/target_repair/current/plan.json" AS_FILE
    RESULT state.lgwf_wf_fix.propose_repair_plan_result
    CONTRACT {
      READ workspace file ".lgwf/self_fix_request.json";
      READ workspace file ".lgwf/self_fix_target.json";
      READ workspace file ".lgwf/target_repair/current/diagnosis.json";
      READ workspace file ".lgwf/target_repair/current/observation.json";
      READ workspace file ".lgwf/target_repair/current/workspace.json";
    };
  ACT CODEX apply_repair_plan
    PROMPT_REF "05_fix_target/agents/apply_repair_plan.md"
    CONTEXT workspace file ".lgwf/target_repair/current/observation.json"
    CONTEXT workspace file ".lgwf/target_repair/current/diagnosis.json"
    CONTEXT workspace file ".lgwf/target_repair/current/plan.json"
    CONTEXT workspace file ".lgwf/target_repair/current/workspace.json"
    OUTPUT_JSON ".lgwf/target_repair/current/apply.json" AS_FILE
    RESULT state.lgwf_wf_fix.apply_repair_plan_result
    CONTRACT {
      READ workspace file ".lgwf/self_fix_request.json";
      READ workspace file ".lgwf/self_fix_target.json";
      READ workspace file ".lgwf/target_repair/current/diagnosis.json";
      READ workspace file ".lgwf/target_repair/current/observation.json";
      READ workspace file ".lgwf/target_repair/current/plan.json";
      READ workspace file ".lgwf/target_repair/current/workspace.json";
      READ workspace file ".lgwf/target_workflow_input.json";
    };
  VERIFY WORKFLOW verify_repair_candidate_with_review
    WORKFLOW "05_fix_target/verify_repair_candidate_workflow.lgwf"
    RESULT state.lgwf_wf_fix.target_repair_current_verification;
  DECIDE PY decide_repair_loop
    SCRIPT "05_fix_target/scripts/decide_repair_loop.py"
    TIMEOUT 60
    RESULT state.lgwf_wf_fix.target_repair_loop_decision
    UPDATES_STATE
    CONTRACT {
      WRITE workspace file ".lgwf/target_repair/current/decision.json";
    };
};

PY route_after_repair_agent_loop
  SCRIPT "05_fix_target/scripts/route_after_repair_agent_loop.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_fix.route_after_repair_agent_loop_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/target_repair/current/decision.json";
    READ workspace file ".lgwf/loops/repair_target/report.json";
  };

PY promote_repair_candidate
  SCRIPT "05_fix_target/scripts/promote_repair_candidate.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_fix.promote_repair_candidate_result
  UPDATES_STATE
  CONTRACT {
  };

PY record_fix_attempt
  SCRIPT "05_fix_target/scripts/record_fix_attempt.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_fix.record_fix_result
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/self_fix_target.json";
  };

PY finish_self_fix
  SCRIPT "07_finish/scripts/finish_self_fix.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_fix.finish_result
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/target_repair/report.json";
    READ workspace file ".lgwf/target_repair/current/decision.json";
    READ workspace file ".lgwf/target_repair/current/observation.json";
    READ workspace file ".lgwf/target_repair/current/verification.json";
    READ workspace file ".lgwf/target_repair/current/change_audit.json";
  };

FLOW run_target_workflow
  THEN observe_target_run
  THEN route_after_observe;

FLOW proxy_target_approval
  THEN submit_target_approval
  THEN observe_target_run;

FLOW prepare_repair_agent_loop
  THEN repair_target
  THEN route_after_repair_agent_loop;

FLOW promote_repair_candidate
  THEN record_fix_attempt
  THEN run_target_workflow;

ROUTE route_after_repair_agent_loop
  WHEN "promote" THEN promote_repair_candidate
  WHEN "finish" THEN finish_self_fix;

ROUTE route_after_observe
  WHEN "approval" THEN proxy_target_approval
  WHEN "observe" THEN observe_target_run
  WHEN "fix" THEN prepare_repair_agent_loop
  WHEN "finish" THEN finish_self_fix;
