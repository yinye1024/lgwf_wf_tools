{
  "version": 1,
  "description": "wf-create Codex JSON output schema registry. Runtime scripts inject only the relevant target file schemas into a single implementation unit context.",
  "codex_output_json_schemas": {
    ".lgwf/create_requirements_proposal.json": {
      "type": "object",
      "required": [
        "workflow_id",
        "workflow_name",
        "target_package_root",
        "purpose",
        "target_users",
        "expected_inputs",
        "expected_outputs",
        "human_approval_points",
        "workflow_shape",
        "proposal_notes",
        "design_rationale"
      ],
      "properties": {
        "workflow_id": {
          "type": "string"
        },
        "workflow_name": {
          "type": "string"
        },
        "target_package_root": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "target_users": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_approval_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workflow_shape": {
          "type": "string",
          "enum": [
            "simple",
            "react",
            "agent_loop"
          ]
        },
        "proposal_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "design_rationale": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    ".lgwf/business_flow_proposal.json": {
      "type": "object",
      "required": [
        "workflow_id",
        "workflow_name",
        "target_package_root",
        "business_goal",
        "stages",
        "stage_dependencies",
        "downstream_step_inputs",
        "risk_notes",
        "design_rationale"
      ],
      "properties": {
        "workflow_id": {
          "type": "string"
        },
        "workflow_name": {
          "type": "string"
        },
        "target_package_root": {
          "type": "string"
        },
        "business_goal": {
          "type": "string"
        },
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "stage_id",
              "stage_name",
              "objective",
              "depends_on",
              "input_sources",
              "outputs",
              "human_approval",
              "key_nodes"
            ],
            "properties": {
              "stage_id": {
                "type": "string"
              },
              "stage_name": {
                "type": "string"
              },
              "objective": {
                "type": "string"
              },
              "depends_on": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "input_sources": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "outputs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "human_approval": {
                "type": "boolean"
              },
              "key_nodes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "stage_dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "from_stage",
              "to_stage",
              "handoff"
            ],
            "properties": {
              "from_stage": {
                "type": "string"
              },
              "to_stage": {
                "type": "string"
              },
              "handoff": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "downstream_step_inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "step_slug",
              "consumes",
              "expected_artifacts"
            ],
            "properties": {
              "step_slug": {
                "type": "string"
              },
              "consumes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "expected_artifacts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "risk_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "design_rationale": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    ".lgwf/step_design_repair_plan.json": {
      "type": "object",
      "required": [
        "repair_scope",
        "observation_summary",
        "must_preserve",
        "must_change",
        "repair_steps",
        "field_level_instructions",
        "forbidden_changes",
        "risk_notes"
      ],
      "properties": {
        "repair_scope": {
          "type": "string"
        },
        "observation_summary": {
          "type": "string"
        },
        "must_preserve": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "must_change": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "repair_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "field_level_instructions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "json_path": {
                "type": "string"
              },
              "operation": {
                "type": "string"
              },
              "instruction": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "forbidden_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    ".lgwf/current_implementation_unit_result.json": {
      "type": "object",
      "required": [
        "unit_id",
        "status",
        "generated_files",
        "handled_failures",
        "remaining_risks",
        "notes"
      ],
      "properties": {
        "unit_id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "partial",
            "failed"
          ]
        },
        "generated_files": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "required": [
                  "path"
                ],
                "properties": {
                  "path": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            ]
          }
        },
        "generated": {
          "type": "object"
        },
        "handled_failures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remaining_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    ".lgwf/implementation_repair_reason.json": {
      "type": "object",
      "required": [
          "repair_required",
          "repair_goal",
          "unit_output_dir",
          "target_files",
          "root_causes",
        "affected_files",
        "repair_units",
        "do_not_change",
        "success_checks"
      ],
      "properties": {
        "repair_required": {
          "type": "boolean"
        },
          "repair_goal": {
            "type": "string"
          },
          "unit_output_dir": {
            "type": "string"
          },
          "target_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "root_causes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affected_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repair_units": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "unit_id",
              "target_files",
              "reason",
              "success_checks"
            ],
            "properties": {
              "unit_id": {
                "type": "string"
              },
              "target_files": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reason": {
                "type": "string"
              },
              "success_checks": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "do_not_change": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "success_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    ".lgwf/implementation_repair_result.json": {
      "type": "object",
      "required": [
        "status",
        "no_op",
        "generated_files",
        "repair_notes",
        "remaining_risks"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "partial",
            "blocked",
            "failed"
          ]
        },
        "no_op": {
          "type": "boolean"
        },
        "generated_files": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "required": [
                  "path"
                ],
                "properties": {
                  "path": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            ]
          }
        },
        "repair_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remaining_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "target_package_output_file_schemas": {
    "entry_contract.json": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "version",
        "workflow_lgwf",
        "work_dir",
        "input_mode",
        "input_schema",
        "auto_human_policy",
        "target_scope",
        "state_boundary",
        "outputs",
        "resume_policy"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "lgwf"
          ]
        },
        "version": {
          "type": "integer"
        },
        "workflow_lgwf": {
          "type": "string",
          "const": "wf/workflow.lgwf"
        },
        "work_dir": {
          "type": "string",
          "const": "ws"
        },
        "input_mode": {
          "type": "string"
        },
        "input_schema": {
          "type": "object",
          "required": [
            "type",
            "required",
            "properties"
          ],
          "properties": {
            "type": {
              "type": "string",
              "const": "object"
            },
            "required": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "properties": {
              "type": "object"
            },
            "example": {
              "type": "object"
            }
          },
          "additionalProperties": true
        },
        "auto_human_policy": {
          "type": "string"
        },
        "target_scope": {
          "type": "object",
          "required": [
            "fields",
            "read_scope",
            "write_scope"
          ]
        },
        "state_boundary": {
          "type": "object",
          "required": [
            "work_dir",
            "runtime_state",
            "source_root"
          ]
        },
        "outputs": {
          "type": "object"
        },
        "resume_policy": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "wf/artifact_contracts.json": {
      "type": "object",
      "required": [
        "bootstrap_inputs",
        "final_outputs",
        "script_writes",
        "runtime_records",
        "delivery_artifacts",
        "pending_confirmations"
      ],
      "properties": {
        "bootstrap_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "final_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "script_writes": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "runtime_records": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "canonical_key",
              "path",
              "produced_by",
              "used_by"
            ],
            "properties": {
              "canonical_key": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "produced_by": {
                "type": "string"
              },
              "used_by": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "delivery_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "canonical_key",
              "default_filename",
              "format",
              "runtime_cache_path",
              "path_template",
              "producer_node",
              "source_evidence_fields",
              "disclosure_fields"
            ],
            "properties": {
              "canonical_key": {
                "type": "string"
              },
              "default_filename": {
                "type": "string"
              },
              "format": {
                "type": "string"
              },
              "runtime_cache_path": {
                "type": "string"
              },
              "path_template": {
                "type": "string"
              },
              "producer_node": {
                "type": "string"
              },
              "source_evidence_fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "disclosure_fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "pending_confirmations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "wf/*/artifact_contracts.json": {
      "type": "object",
      "required": [
        "bootstrap_inputs",
        "final_outputs"
      ],
      "properties": {
        "bootstrap_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "final_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runtime_records": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
