  "target_package_output_file_schemas": {
    "entry_contract.json": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "version",
        "workflow_lgwf",
        "work_dir",
        "input_mode",
        "input_schema",
        "auto_human_policy",
        "target_scope",
        "state_boundary",
        "outputs",
        "resume_policy"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "lgwf"
          ]
        },
        "version": {
          "type": "integer"
        },
        "workflow_lgwf": {
          "type": "string",
          "const": "wf/workflow.lgwf"
        },
        "work_dir": {
          "type": "string",
          "const": "ws"
        },
        "input_mode": {
          "type": "string"
