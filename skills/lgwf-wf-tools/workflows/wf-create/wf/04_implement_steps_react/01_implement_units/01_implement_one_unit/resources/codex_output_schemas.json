          "required": [
            "fields",
            "read_scope",
            "write_scope"
          ]
        },
        "state_boundary": {
          "type": "object",
          "required": [
            "work_dir",
            "runtime_state",
            "source_root"
          ]
        },
        "outputs": {
          "type": "object"
        },
        "resume_policy": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
