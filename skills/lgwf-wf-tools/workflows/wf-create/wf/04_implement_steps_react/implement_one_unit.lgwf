WORKFLOW implement_one_unit;
ENTRY prepare_current_implementation_unit;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  result_path "lgwf_wf_create.implement_one_unit.{node}";
}

PY prepare_current_implementation_unit
  SCRIPT "scripts/prepare_current_implementation_unit.py"
  INPUT state.lgwf_wf_create.current_implementation_unit
  TIMEOUT 30
  RESULT state.lgwf_wf_create.prepare_current_implementation_unit_result
  UPDATES_STATE {
    WRITE state.lgwf_wf_create.current_implementation_unit_context;
    WRITE state.lgwf_wf_create.current_implementation_unit_output_files;
    WRITE state.lgwf_wf_create.current_implementation_unit_output_dirs;
    WRITE state.lgwf_wf_create.current_implementation_unit_output_dir;
  }
  CONTRACT {
    READ state.lgwf_wf_create.current_implementation_unit;
    WRITE state.lgwf_wf_create.current_implementation_unit_context;
    WRITE state.lgwf_wf_create.current_implementation_unit_output_files;
    WRITE state.lgwf_wf_create.current_implementation_unit_output_dirs;
    WRITE state.lgwf_wf_create.current_implementation_unit_output_dir;
    WRITE workspace file ".lgwf/current_implementation_unit_context.json";
    WRITE workspace dir ".lgwf/implementation_stage";
  };

CODEX implement_current_unit
  PROMPT "agents/act_unit.md"
  CONTEXT workflow file "agents/spec.md"
  CONTEXT workspace file ".lgwf/current_implementation_unit_context.json"
  OUTPUT_JSON ".lgwf/current_implementation_unit_result.json" AS_FILE
  TIMEOUT 1200
  RESULT state.lgwf_wf_create.current_implementation_unit_result
  CONTRACT {
    READ workflow file "agents/spec.md";
    READ state.lgwf_wf_create.current_implementation_unit;
    READ workspace file ".lgwf/current_implementation_unit_context.json";
    WRITE state.lgwf_wf_create.current_implementation_unit_result;
    WRITE workspace dir ".lgwf/implementation_stage";
    WRITE workspace file ".lgwf/current_implementation_unit_result.json";
  };

PY publish_current_implementation_unit_result
  SCRIPT "scripts/publish_current_implementation_unit_result.py"
  TIMEOUT 30
  RESULT state.lgwf_wf_create.current_implementation_unit_result
  UPDATES_STATE {
    WRITE state.lgwf_wf_create.current_implementation_unit_result;
  }
  CONTRACT {
    READ workspace file ".lgwf/implementation_context.json";
    READ workspace file ".lgwf/current_implementation_unit_context.json";
    READ workspace file ".lgwf/current_implementation_unit_result.json";
    READ workspace dir ".lgwf/implementation_stage";
    WRITE state.lgwf_wf_create.current_implementation_unit_result;
  };

FLOW prepare_current_implementation_unit
  THEN implement_current_unit
  THEN publish_current_implementation_unit_result;
