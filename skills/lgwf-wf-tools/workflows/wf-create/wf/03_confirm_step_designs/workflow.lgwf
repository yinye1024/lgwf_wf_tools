WORKFLOW implement_draft;
ENTRY prepare_dsl_reference_context;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
}

PY prepare_dsl_reference_context
  SCRIPT "scripts/prepare_dsl_reference_context.py"
  TIMEOUT 30
  RESULT state.lgwf_wf_create.dsl_reference_context
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/create_reference_context/dsl-assist/create-workflow.md";
    WRITE workspace file ".lgwf/create_reference_context/dsl-assist/dsl_reference_context.json";
    WRITE workspace file ".lgwf/create_reference_context/dsl-assist/*.md";
    WRITE workspace file ".lgwf/create_reference_context/dsl-assist/guide.md";
    WRITE workspace file ".lgwf/create_reference_context/dsl-assist/workflow-audit-checklist.md";
    WRITE workspace file ".lgwf/create_reference_context/scaffold/*.md";
    WRITE workspace file ".lgwf/create_reference_context/scaffold/*.md|*.json";
    WRITE workspace file ".lgwf/create_reference_context/scaffold/scaffold_package_template.json";
    WRITE workspace file ".lgwf/create_reference_context/scaffold/scaffold_result_contract.md";
    WRITE workspace file ".lgwf/create_reference_context/scaffold/scaffold_template_spec.md";
    WRITE workspace file ".lgwf/create_reference_context/workflow-modular-development/LGWF_WF_MODULAR_DEVELOPMENT.md";
    WRITE workspace file ".lgwf/create_reference_context/module-contract/module-contract.md";
    WRITE workspace file ".lgwf/create_reference_context/dsl_reference_context.json";
  };

CODEX design_steps_react
  PROMPT "agents/design_steps_react.md"
  CONTEXT workspace dir ".lgwf/create_reference_context/dsl-assist"
  CONTEXT workspace dir ".lgwf/create_reference_context/scaffold"
  CONTEXT workspace dir ".lgwf/create_reference_context/workflow-modular-development"
  TARGET_DIRS state.lgwf_wf_create.creation_context_dirs
  TARGET_FILES state.lgwf_wf_create.creation_context_files
  OUTPUT_JSON ".lgwf/step_designs_proposal.json" AS_FILE
  TIMEOUT 900
  RESULT state.lgwf_wf_create.step_design_result
  CONTRACT {
    READ workspace file ".lgwf/business_flow.json";
    READ workspace file ".lgwf/business_flow_proposal.json";
    READ workspace file ".lgwf/create_reference_context/dsl-assist/*.md";
    READ workspace file ".lgwf/create_reference_context/dsl-assist/create-workflow.md";
    READ workspace file ".lgwf/create_reference_context/scaffold/scaffold_result_contract.md";
    READ workspace file ".lgwf/create_reference_context/scaffold/scaffold_template_spec.md";
    READ workspace file ".lgwf/create_reference_context/workflow-modular-development/LGWF_WF_MODULAR_DEVELOPMENT.md";
    READ workspace file ".lgwf/step_designs.json";
    WRITE workspace file ".lgwf/step_designs_proposal.json";
    READ workspace dir ".lgwf/create_reference_context/dsl-assist";
    READ workspace dir ".lgwf/create_reference_context/scaffold";
    READ workspace dir ".lgwf/create_reference_context/workflow-modular-development";
  };

PY prepare_step_design_confirmation
  SCRIPT "scripts/prepare_step_design_confirmation.py"
  TIMEOUT 30
  RESULT state.lgwf_wf_create.prepare_step_design_confirmation_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/step_designs_proposal.json";
  };

REVIEW confirm_step_designs
  PROMPT_REF "confirm_step_designs.md"
  CONTEXT state.lgwf_wf_create.step_design_confirmation_context
  RESULT state.lgwf_wf_create.step_design_decision_result
  PERSIST ".lgwf/step_design_confirmation_record.json"
  OPTIONS ["approve", "revise", "reject"]
  CONTRACT {
    WRITE workspace file ".lgwf/step_design_confirmation_record.json";
    READ state.lgwf_wf_create.step_design_confirmation_context;
  };

PY apply_confirmed_step_designs
  SCRIPT "scripts/apply_confirmed_step_designs.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_create.apply_step_designs_result
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/step_designs.json";
  };

PY prepare_implementation_context
  SCRIPT "scripts/prepare_implementation_context.py"
  TIMEOUT 30
  RESULT state.lgwf_wf_create.implementation_context
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/business_flow.json";
    READ workspace file ".lgwf/create_requirements.json";
    READ workspace file ".lgwf/implementation_context.json";
    READ workspace file ".lgwf/scaffold_package_result.json";
    WRITE workspace file ".lgwf/implementation_context.json";
  };

FLOW {
  prepare_dsl_reference_context THEN design_steps_react THEN prepare_step_design_confirmation THEN confirm_step_designs;

  confirm_step_designs
    WHEN "approve" THEN apply_confirmed_step_designs
    WHEN "revise" THEN confirm_step_designs
    WHEN "reject" THEN FAIL_ALL;

  apply_confirmed_step_designs THEN prepare_implementation_context;
}
