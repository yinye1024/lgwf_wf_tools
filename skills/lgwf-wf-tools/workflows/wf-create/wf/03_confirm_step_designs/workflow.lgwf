WORKFLOW implement_draft;
ENTRY reference_context;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
}

STEP reference_context
  WORKFLOW "01_reference_context/workflow.lgwf"
  CONTRACT {
    WRITE workspace file ".lgwf/create_reference_context/dsl-assist/create-workflow.md";
    WRITE workspace file ".lgwf/create_reference_context/dsl-assist/guide.md";
    WRITE workspace file ".lgwf/create_reference_context/dsl-assist/workflow-audit-checklist.md";
    WRITE workspace file ".lgwf/create_reference_context/workflow-modular-development/LGWF_WF_MODULAR_DEVELOPMENT.md";
    WRITE workspace file ".lgwf/create_reference_context/module-contract/module-contract.md";
    WRITE workspace file ".lgwf/create_reference_context/step-design-reference-index.md";
    WRITE workspace file ".lgwf/create_reference_context/implementation-reference-index.md";
  };

STEP step_design_proposal
  WORKFLOW "02_step_design_proposal/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/business_flow.json";
    READ workspace file ".lgwf/create_requirements.json";
    READ workspace file ".lgwf/scaffold_package_result.json";
    READ workspace file ".lgwf/create_reference_context/step-design-reference-index.md";
    READ workspace dir ".lgwf/create_reference_context";
    WRITE workspace file ".lgwf/step_design_proposal_react_context.json";
    WRITE workspace file ".lgwf/step_designs_proposal_decision.json";
    WRITE workspace file ".lgwf/step_designs_proposal.json";
    WRITE workspace file ".lgwf/step_designs_proposal_quality_gate.json";
  };

STEP step_design_review
  WORKFLOW "03_step_design_review/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/business_flow.json";
    READ workspace file ".lgwf/create_requirements.json";
    READ workspace file ".lgwf/scaffold_package_result.json";
    READ workspace file ".lgwf/step_designs_proposal.json";
    READ workspace file ".lgwf/step_designs_proposal_quality_gate.json";
    WRITE workspace file ".lgwf/step_design_confirmation_record.json";
    WRITE workspace file ".lgwf/step_designs.json";
    WRITE workspace file ".lgwf/implementation_context.json";
    WRITE state.lgwf_wf_create.step_designs;
  };

FLOW reference_context
  THEN step_design_proposal
  THEN step_design_review;
