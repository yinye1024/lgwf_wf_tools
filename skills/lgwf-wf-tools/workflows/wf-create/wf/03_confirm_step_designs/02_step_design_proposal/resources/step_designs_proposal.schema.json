{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "wf-create step_designs_proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "workflow_name",
    "target_package_root",
    "package_profile",
    "source_business_flow_stages",
    "directory_designs",
    "file_designs",
    "step_designs",
    "design_rationale"
  ],
  "properties": {
    "workflow_id": { "type": "string", "minLength": 1 },
    "workflow_name": { "type": "string", "minLength": 1 },
    "target_package_root": { "type": "string", "minLength": 1 },
    "package_profile": { "type": "string", "minLength": 1 },
    "source_business_flow_stages": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "directory_designs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/directory_design" }
    },
    "file_designs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/file_design" }
    },
    "step_designs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step_design" }
    },
    "design_rationale": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "safe_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^[A-Za-z]:" },
          { "pattern": "^/" },
          { "pattern": "(^|/)\\.\\.(?:/|$)" },
          { "pattern": "^\\.lgwf(?:/|$)" }
        ]
      }
    },
    "safe_runtime_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^[A-Za-z]:" },
          { "pattern": "^/" },
          { "pattern": "(^|/)\\.\\.(?:/|$)" }
        ]
      }
    },
    "string_list": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "directory_design": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "purpose", "owner_step", "expected_files", "forbidden", "source_refs"],
      "properties": {
        "path": { "$ref": "#/$defs/safe_path" },
        "purpose": { "type": "string", "minLength": 1 },
        "owner_step": { "type": "string", "minLength": 1 },
        "expected_files": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/safe_path" }
        },
        "forbidden": { "$ref": "#/$defs/string_list" },
        "source_refs": { "$ref": "#/$defs/string_list" }
      }
    },
    "file_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "owner_step",
        "purpose",
        "required_structure",
        "reads",
        "writes",
        "dependencies",
        "acceptance_notes",
        "forbidden",
        "source_refs",
        "content_mode"
      ],
      "properties": {
        "path": { "$ref": "#/$defs/safe_path" },
        "kind": { "type": "string", "minLength": 1 },
        "owner_step": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "required_structure": { "$ref": "#/$defs/string_list" },
        "reads": { "$ref": "#/$defs/string_list" },
        "writes": { "$ref": "#/$defs/string_list" },
        "dependencies": { "$ref": "#/$defs/string_list" },
        "acceptance_notes": { "$ref": "#/$defs/string_list" },
        "forbidden": { "$ref": "#/$defs/string_list" },
        "source_refs": { "$ref": "#/$defs/string_list" },
        "content_mode": {
          "type": "string",
          "enum": ["exact", "contract"]
        },
        "exact_content": { "type": "string", "minLength": 1 },
        "script_contract": {
          "type": "object",
          "required": [
            "entrypoint",
            "input_files",
            "output_files",
            "required_functions",
            "behavior",
            "error_handling",
            "output_shape"
          ],
          "properties": {
            "entrypoint": { "type": "string", "minLength": 1 },
            "input_files": { "$ref": "#/$defs/string_list" },
            "output_files": { "$ref": "#/$defs/string_list" },
            "required_functions": { "$ref": "#/$defs/string_list" },
            "behavior": { "$ref": "#/$defs/string_list" },
            "error_handling": { "$ref": "#/$defs/string_list" },
            "output_shape": {
              "type": ["object", "array", "string"],
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "prompt_contract": {
          "type": "object",
          "additionalProperties": true
        },
        "markdown_contract": {
          "type": "object",
          "required": ["sections"],
          "properties": {
            "sections": { "$ref": "#/$defs/string_list" }
          },
          "additionalProperties": true
        },
        "json_contract": {
          "type": "object",
          "required": ["top_level_fields", "required", "consumer"],
          "properties": {
            "top_level_fields": { "$ref": "#/$defs/string_list" },
            "required": { "$ref": "#/$defs/string_list" },
            "consumer": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        },
        "test_contract": {
          "type": "object",
          "required": ["test_framework", "scope", "fixtures", "acceptance"],
          "properties": {
            "test_framework": { "type": "string", "minLength": 1 },
            "scope": { "$ref": "#/$defs/string_list" },
            "fixtures": { "$ref": "#/$defs/string_list" },
            "acceptance": { "$ref": "#/$defs/string_list" }
          },
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "lgwf_workflow" } },
            "required": ["kind"]
          },
          "then": {
            "properties": { "content_mode": { "const": "exact" } },
            "required": ["exact_content"]
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "prompt" } },
            "required": ["kind"]
          },
          "then": {
            "properties": { "content_mode": { "const": "exact" } },
            "required": ["exact_content"]
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "python_script" } },
            "required": ["kind"]
          },
          "then": {
            "properties": { "content_mode": { "const": "contract" } },
            "required": ["script_contract"]
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "markdown_doc" } },
            "required": ["kind"]
          },
          "then": {
            "properties": { "content_mode": { "const": "contract" } },
            "required": ["markdown_contract"]
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "json_contract" } },
            "required": ["kind"]
          },
          "then": {
            "properties": { "content_mode": { "const": "contract" } },
            "required": ["json_contract"]
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "test" } },
            "required": ["kind"]
          },
          "then": {
            "properties": { "content_mode": { "const": "contract" } },
            "required": ["test_contract"]
          }
        }
      ]
    },
    "step_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_slug",
        "step_name",
        "stage_id",
        "goal",
        "inputs",
        "outputs",
        "dependencies",
        "implementation_suggestions",
        "acceptance_notes",
        "out_of_scope",
        "confirmation_points",
        "target_files",
        "target_dirs",
        "runtime_artifacts",
        "source_refs",
        "risk_notes"
      ],
      "properties": {
        "step_slug": { "type": "string", "minLength": 1 },
        "step_name": { "type": "string", "minLength": 1 },
        "stage_id": { "type": "string", "minLength": 1 },
        "goal": { "type": "string", "minLength": 1 },
        "inputs": { "$ref": "#/$defs/string_list" },
        "outputs": { "$ref": "#/$defs/string_list" },
        "dependencies": { "$ref": "#/$defs/string_list" },
        "implementation_suggestions": { "$ref": "#/$defs/string_list" },
        "acceptance_notes": { "$ref": "#/$defs/string_list" },
        "out_of_scope": { "$ref": "#/$defs/string_list" },
        "confirmation_points": { "$ref": "#/$defs/string_list" },
        "target_files": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/safe_path" }
        },
        "target_dirs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/safe_path" }
        },
        "runtime_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/safe_runtime_path" }
        },
        "source_refs": { "$ref": "#/$defs/string_list" },
        "risk_notes": { "$ref": "#/$defs/string_list" }
      }
    }
  }
}
