WORKFLOW summarize_create_result;
ENTRY summarize_create_result;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 300;
}

PY summarize_create_result
  SCRIPT "scripts/summarize_create_result.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_create.summary_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/business_flow.json";
    READ workspace file ".lgwf/create_requirements.json";
    READ workspace file ".lgwf/implementation_result.json";
  };
