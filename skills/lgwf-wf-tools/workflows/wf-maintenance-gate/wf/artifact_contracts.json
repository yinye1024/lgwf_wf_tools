{
  "bootstrap_inputs": [
    ".lgwf/maintenance_gate_request.json"
  ],
  "final_outputs": [
    ".lgwf/change_context.json",
    ".lgwf/path_context.json",
    ".lgwf/impact_classification.json",
    ".lgwf/verification_plan_proposal.json",
    ".lgwf/verification_plan_confirmation_context.json",
    ".lgwf/verification_plan_approval.json",
    ".lgwf/verification_plan.json",
    ".lgwf/verification_results.json",
    ".lgwf/failure_routes.json",
    ".lgwf/maintenance_gate_summary.json",
    "reports/wf-maintenance-gate/report.md"
  ],
  "script_writes": {
    "normalize_request": [
      ".lgwf/maintenance_gate_request.json",
      ".lgwf/path_context.json"
    ],
    "collect_change_context": [
      ".lgwf/change_context.json"
    ],
    "classify_impact": [
      ".lgwf/impact_classification.json"
    ],
    "build_verification_plan_proposal": [
      ".lgwf/verification_plan_proposal.json"
    ],
    "prepare_verification_plan_confirmation": [
      ".lgwf/verification_plan_confirmation_context.json"
    ],
    "prepare_verification_plan_revision_confirmation": [
      ".lgwf/verification_plan_confirmation_context.json",
      ".lgwf/verification_plan_proposal.json"
    ],
    "apply_confirmed_verification_plan": [
      ".lgwf/verification_plan.json"
    ],
    "run_confirmed_commands": [
      ".lgwf/verification_results.json"
    ],
    "build_failure_routes": [
      ".lgwf/failure_routes.json"
    ],
    "build_summary": [
      ".lgwf/maintenance_gate_summary.json"
    ],
    "render_report": [
      "reports/wf-maintenance-gate/report.md"
    ]
  }
}
