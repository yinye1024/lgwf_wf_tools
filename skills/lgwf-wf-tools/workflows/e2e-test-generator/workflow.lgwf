WORKFLOW lgwf_e2e_test_generator;
ENTRY prepare_target_request_context;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  result_path "lgwf_e2e.results.{node}";
}

PY prepare_target_request_context
  SCRIPT "01_inspect_target/00_collect_target_request/scripts/prepare_target_request_context.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.prepare_target_request_context_result
  UPDATES_STATE
  CONTRACT {
  };

APPROVAL collect_target_request
  PROMPT_REF "01_inspect_target/00_collect_target_request/confirm_target_request.md"
  READ state.lgwf_e2e.target_request_context
  WRITE state.lgwf_e2e.target_request
  RESULT state.lgwf_e2e.target_request_result
  PERSIST ".lgwf/e2e_target_request.json"
  POLL 1
  CONTRACT {
    WRITE workspace file ".lgwf/e2e_target_request.json";
    READ state.lgwf_e2e.target_request_context;
    WRITE state.lgwf_e2e.target_request;
  };

STEP inspect_target
  WORKFLOW "01_inspect_target/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/e2e_target_request.json";
    WRITE workspace file ".lgwf/e2e_target_request.normalized.json";
    WRITE workspace file ".lgwf/e2e_workflow_graph.json";
    WRITE workspace file ".lgwf/e2e_business_flow_summary.json";
  };

STEP derive_coverage_matrix
  WORKFLOW "02_derive_coverage_matrix/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/e2e_business_flow_summary.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    READ workspace file ".lgwf/e2e_workflow_graph.json";
    WRITE workspace file ".lgwf/e2e_coverage_matrix.json";
  };

PY route_script_flow_selection
  SCRIPT "00_route_selection/scripts/route_script_flow_selection.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.route_script_flow_selection_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
  };

STEP script_flow_e2e
  WORKFLOW "03_script_flow_e2e/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    READ workspace file ".lgwf/e2e_workflow_graph.json";
    WRITE workspace file ".lgwf/e2e_script_flow_generation.json";
    WRITE workspace file ".lgwf/e2e_script_flow_observe.json";
  };

PY route_runtime_fake_selection
  SCRIPT "00_route_selection/scripts/route_runtime_fake_selection.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.route_runtime_fake_selection_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
  };

STEP runtime_fake_e2e
  WORKFLOW "04_runtime_fake_e2e/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    READ workspace file ".lgwf/e2e_workflow_graph.json";
    WRITE workspace file ".lgwf/e2e_runtime_fake_generation.json";
    WRITE workspace file ".lgwf/e2e_runtime_fake_observe.json";
  };

PY route_real_positive_selection
  SCRIPT "00_route_selection/scripts/route_real_positive_selection.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.route_real_positive_selection_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
  };

STEP real_positive_e2e
  WORKFLOW "05_real_positive_e2e/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/e2e_business_flow_summary.json";
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    READ workspace file ".lgwf/e2e_workflow_graph.json";
    WRITE workspace file ".lgwf/e2e_real_positive_design.json";
    WRITE workspace file ".lgwf/e2e_real_positive_generation.json";
    WRITE workspace file ".lgwf/e2e_real_positive_observe.json";
  };

PY route_wf_fix_positive_selection
  SCRIPT "00_route_selection/scripts/route_wf_fix_positive_selection.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.route_wf_fix_positive_selection_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
  };

STEP wf_fix_positive_e2e
  WORKFLOW "06_wf_fix_positive_e2e/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_real_positive_design.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    READ workspace file ".lgwf/e2e_workflow_graph.json";
    WRITE workspace file ".lgwf/e2e_wf_fix_positive_generation.json";
    WRITE workspace file ".lgwf/e2e_wf_fix_positive_observe.json";
  };

STEP finish
  WORKFLOW "07_finish/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_real_positive_generation.json";
    READ workspace file ".lgwf/e2e_real_positive_observe.json";
    READ workspace file ".lgwf/e2e_runtime_fake_generation.json";
    READ workspace file ".lgwf/e2e_runtime_fake_observe.json";
    READ workspace file ".lgwf/e2e_script_flow_generation.json";
    READ workspace file ".lgwf/e2e_script_flow_observe.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    READ workspace file ".lgwf/e2e_wf_fix_positive_generation.json";
    READ workspace file ".lgwf/e2e_wf_fix_positive_observe.json";
    WRITE workspace file "reports/e2e-test-generator/report.json";
    WRITE workspace file "reports/e2e-test-generator/report.md";
  };

FLOW prepare_target_request_context
  THEN collect_target_request
  THEN inspect_target
  THEN derive_coverage_matrix
  THEN route_script_flow_selection;

FLOW script_flow_e2e
  THEN route_runtime_fake_selection;

FLOW runtime_fake_e2e
  THEN route_real_positive_selection;

FLOW real_positive_e2e
  THEN route_wf_fix_positive_selection;

FLOW wf_fix_positive_e2e
  THEN finish;

ROUTE route_script_flow_selection
  WHEN "run" THEN script_flow_e2e
  WHEN "skip" THEN route_runtime_fake_selection;

ROUTE route_runtime_fake_selection
  WHEN "run" THEN runtime_fake_e2e
  WHEN "skip" THEN route_real_positive_selection;

ROUTE route_real_positive_selection
  WHEN "run" THEN real_positive_e2e
  WHEN "skip" THEN route_wf_fix_positive_selection;

ROUTE route_wf_fix_positive_selection
  WHEN "run" THEN wf_fix_positive_e2e
  WHEN "skip" THEN finish;
