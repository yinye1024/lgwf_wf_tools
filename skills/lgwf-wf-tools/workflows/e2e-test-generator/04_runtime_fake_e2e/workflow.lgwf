WORKFLOW runtime_fake_e2e;
ENTRY prepare_runtime_fake_repair_context;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  result_path "lgwf_e2e.runtime_fake.results.{node}";
}

PY prepare_runtime_fake_repair_context
  SCRIPT "00_prepare/scripts/prepare_runtime_fake_repair_context.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.runtime_fake_prepare_repair_context_result
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/e2e_runtime_fake_observe.json";
    WRITE workspace file ".lgwf/e2e_runtime_fake_repair_context.json";
  };

PY design_runtime_fake_e2e
  SCRIPT "01_design/scripts/design_runtime_fake_e2e.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.runtime_fake_design_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_runtime_fake_observe.json";
    READ workspace file ".lgwf/e2e_runtime_fake_repair_context.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    READ workspace file ".lgwf/e2e_workflow_graph.json";
    WRITE workspace file ".lgwf/e2e_runtime_fake_design.json";
  };

PY generate_runtime_fake_e2e
  SCRIPT "02_generate/scripts/generate_runtime_fake_e2e.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.runtime_fake_generation_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_runtime_fake_design.json";
    READ workspace file ".lgwf/e2e_runtime_fake_repair_context.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    WRITE workspace file ".lgwf/e2e_runtime_fake_generation.json";
  };

PY validate_runtime_fake_e2e
  SCRIPT "03_validate/scripts/validate_runtime_fake_e2e.py"
  TIMEOUT 180
  RESULT state.lgwf_e2e.runtime_fake_validation_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_runtime_fake_design.json";
    READ workspace file ".lgwf/e2e_runtime_fake_generation.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    WRITE workspace file ".lgwf/e2e_runtime_fake_observe.json";
  };

FLOW prepare_runtime_fake_repair_context
  THEN design_runtime_fake_e2e
  THEN generate_runtime_fake_e2e
  THEN validate_runtime_fake_e2e;
