WORKFLOW script_flow_e2e;
ENTRY prepare_script_flow_observe_feedback;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  result_path "lgwf_e2e.script_flow.results.{node}";
}

PY prepare_script_flow_observe_feedback
  SCRIPT "00_prepare/scripts/prepare_script_flow_observe_feedback.py"
  RESULT state.lgwf_e2e.script_flow_observe_feedback_result
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/e2e_script_flow_observe.json";
  };

PY design_script_flow_e2e
  SCRIPT "01_design/scripts/design_script_flow_e2e.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.script_flow_design_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_script_flow_observe.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    READ workspace file ".lgwf/e2e_workflow_graph.json";
    WRITE workspace file ".lgwf/e2e_script_flow_design.json";
  };

PY generate_script_flow_e2e
  SCRIPT "02_generate/scripts/generate_script_flow_e2e.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.script_flow_generation_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_script_flow_design.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    WRITE workspace file ".lgwf/e2e_script_flow_generation.json";
  };

PY validate_script_flow_e2e
  SCRIPT "03_validate/scripts/validate_script_flow_e2e.py"
  TIMEOUT 180
  RESULT state.lgwf_e2e.script_flow_validation_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_coverage_matrix.json";
    READ workspace file ".lgwf/e2e_script_flow_design.json";
    READ workspace file ".lgwf/e2e_script_flow_generation.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    WRITE workspace file ".lgwf/e2e_script_flow_observe.json";
  };

FLOW prepare_script_flow_observe_feedback
  THEN design_script_flow_e2e
  THEN generate_script_flow_e2e
  THEN validate_script_flow_e2e;
