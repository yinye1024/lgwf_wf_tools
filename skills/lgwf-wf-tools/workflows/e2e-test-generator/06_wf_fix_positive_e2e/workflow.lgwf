WORKFLOW wf_fix_positive_e2e;
ENTRY prepare_wf_fix_positive_observe_feedback;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  result_path "lgwf_e2e.wf_fix_positive.results.{node}";
}

PY prepare_wf_fix_positive_observe_feedback
  SCRIPT "00_prepare/scripts/prepare_wf_fix_positive_observe_feedback.py"
  RESULT state.lgwf_e2e.wf_fix_positive_observe_feedback_result
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/e2e_wf_fix_positive_observe.json";
  };

CONTEXT_SET wf_fix_positive_e2e_shared_context {
  workspace file ".lgwf/e2e_target_request.normalized.json";
  workspace file ".lgwf/e2e_workflow_graph.json";
  workspace file ".lgwf/e2e_coverage_matrix.json";
  workspace file ".lgwf/e2e_real_positive_design.json";
}

CONTEXT_SET wf_fix_positive_e2e_design_context {
  workspace file ".lgwf/e2e_wf_fix_positive_design.json";
}

REACT wf_fix_positive_e2e_react MAX 3
  SPEC "01_design/agents/spec.md"
  CONTEXT wf_fix_positive_e2e_shared_context
  CONTRACT {
  }
  REASON CODEX
    PROMPT "01_design/agents/reason.md"
    CONTEXT workspace file ".lgwf/e2e_wf_fix_positive_observe.json"
    TARGET_DIRS state.lgwf_e2e.target_dirs
    TARGET_FILES state.lgwf_e2e.target_files
    OUTPUT_JSON ".lgwf/e2e_wf_fix_positive_design.json"
    RESULT state.lgwf_e2e.wf_fix_positive_reason_result
    CONTRACT {
      READ workspace file ".lgwf/e2e_coverage_matrix.json";
      READ workspace file ".lgwf/e2e_real_positive_design.json";
      READ workspace file ".lgwf/e2e_target_request.normalized.json";
      READ workspace file ".lgwf/e2e_wf_fix_positive_observe.json";
      READ workspace file ".lgwf/e2e_workflow_graph.json";
      WRITE workspace file ".lgwf/e2e_wf_fix_positive_design.json";
    }
  ACT CODEX
    PROMPT "02_generate/agents/act.md"
    CONTEXT wf_fix_positive_e2e_design_context
    TARGET_DIRS state.lgwf_e2e.target_dirs
    TARGET_FILES state.lgwf_e2e.target_files
    OUTPUT_JSON ".lgwf/e2e_wf_fix_positive_generation.json"
    RESULT state.lgwf_e2e.wf_fix_positive_act_result
    CONTRACT {
      READ workspace file ".lgwf/e2e_coverage_matrix.json";
      READ workspace file ".lgwf/e2e_real_positive_design.json";
      READ workspace file ".lgwf/e2e_target_request.normalized.json";
      READ workspace file ".lgwf/e2e_wf_fix_positive_design.json";
      READ workspace file ".lgwf/e2e_workflow_graph.json";
      WRITE workspace file ".lgwf/e2e_wf_fix_positive_generation.json";
    }
  OBSERVE CODEX
    PROMPT "03_validate/agents/observe.md"
    CONTEXT wf_fix_positive_e2e_design_context
    CONTEXT workspace file ".lgwf/e2e_wf_fix_positive_generation.json"
    TARGET_DIRS state.lgwf_e2e.target_dirs
    TARGET_FILES state.lgwf_e2e.target_files
    OUTPUT_JSON ".lgwf/e2e_wf_fix_positive_observe.json"
    RESULT state.lgwf_e2e.wf_fix_positive_observe_result
    CONTRACT {
      READ workspace file ".lgwf/e2e_coverage_matrix.json";
      READ workspace file ".lgwf/e2e_real_positive_design.json";
      READ workspace file ".lgwf/e2e_target_request.normalized.json";
      READ workspace file ".lgwf/e2e_wf_fix_positive_design.json";
      READ workspace file ".lgwf/e2e_wf_fix_positive_generation.json";
      WRITE workspace file ".lgwf/e2e_wf_fix_positive_observe.json";
    }
  DECIDE PY
    SCRIPT "04_repair/scripts/decide_wf_fix_positive.py"
    RESULT state.lgwf_e2e.wf_fix_positive_decide_result
    UPDATES_STATE
    CONTRACT {
    };

FLOW prepare_wf_fix_positive_observe_feedback
  THEN wf_fix_positive_e2e_react;
