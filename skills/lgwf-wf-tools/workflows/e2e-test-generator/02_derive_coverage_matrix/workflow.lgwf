WORKFLOW derive_coverage_matrix;
ENTRY build_coverage_matrix;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  result_path "lgwf_e2e.coverage.results.{node}";
}

PY build_coverage_matrix
  SCRIPT "01_build_coverage_matrix/scripts/build_coverage_matrix.py"
  TIMEOUT 60
  RESULT state.lgwf_e2e.coverage_matrix_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/e2e_business_flow_summary.json";
    READ workspace file ".lgwf/e2e_target_request.normalized.json";
    READ workspace file ".lgwf/e2e_workflow_graph.json";
    WRITE workspace file ".lgwf/e2e_coverage_matrix.json";
  };
