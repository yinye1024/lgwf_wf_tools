WORKFLOW prompt_upgrade_confirm_upgrade;
ENTRY prepare_prompt_upgrade_confirmation;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  result_path "lgwf_wf_prompt_upgrade.results.{node}";
}

PY prepare_prompt_upgrade_confirmation
  SCRIPT "scripts/prepare_prompt_upgrade_confirmation.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_prompt_upgrade.prepare_confirmation_result
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/prompt_upgrade/confirmation_context.json";
    READ workspace file ".lgwf/prompt_upgrade/proposal_review.json";
    READ workspace file ".lgwf/prompt_upgrade/proposal.json";
    READ workspace file ".lgwf/prompt_upgrade/inventory.json";
    READ workspace file ".lgwf/prompt_upgrade/analysis.json";
  };

REVIEW confirm_prompt_upgrade
  PROMPT_REF "confirm_prompt_upgrade.md"
  CONTEXT state.lgwf_wf_prompt_upgrade.prompt_upgrade_confirmation_context
  RESULT state.lgwf_wf_prompt_upgrade.prompt_upgrade_decision_review_result
  PERSIST ".lgwf/prompt_upgrade/decision_review.json"
  OPTIONS ["approve", "revise", "reject"]
  CONTRACT {
    READ state.lgwf_wf_prompt_upgrade.prompt_upgrade_confirmation_context;
    READ workspace file ".lgwf/prompt_upgrade/confirmation_context.json";
    WRITE workspace file ".lgwf/prompt_upgrade/decision_review.json";
  };

PY validate_prompt_upgrade_decision
  SCRIPT "scripts/validate_prompt_upgrade_decision.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_prompt_upgrade.validate_decision_result
  UPDATES_STATE
  CONTRACT {
    WRITE workspace file ".lgwf/prompt_upgrade/decision.json";
    READ workspace file ".lgwf/prompt_upgrade/proposal.json";
    READ workspace file ".lgwf/prompt_upgrade/decision_review.json";
  };

PY route_after_prompt_upgrade_decision
  SCRIPT "scripts/route_after_prompt_upgrade_decision.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_prompt_upgrade.route_decision_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/prompt_upgrade/decision.json";
  };

PY finish_prompt_upgrade_confirmation
  SCRIPT "scripts/finish_prompt_upgrade_confirmation.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_prompt_upgrade.finish_confirmation_result
  UPDATES_STATE
  CONTRACT {
  };

FLOW prepare_prompt_upgrade_confirmation
  THEN confirm_prompt_upgrade
  THEN validate_prompt_upgrade_decision
  THEN route_after_prompt_upgrade_decision;

ROUTE route_after_prompt_upgrade_decision
  WHEN "apply" THEN finish_prompt_upgrade_confirmation
  WHEN "summarize" THEN finish_prompt_upgrade_confirmation
  WHEN "reject" THEN FAIL_ALL;
