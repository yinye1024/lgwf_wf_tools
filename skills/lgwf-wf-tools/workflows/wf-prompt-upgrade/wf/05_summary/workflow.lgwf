WORKFLOW prompt_upgrade_summary;
ENTRY summarize_prompt_upgrade;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  result_path "lgwf_wf_prompt_upgrade.results.{node}";
}

PY summarize_prompt_upgrade
  SCRIPT "scripts/summarize_prompt_upgrade.py"
  TIMEOUT 60
  RESULT state.lgwf_wf_prompt_upgrade.summary_result
  UPDATES_STATE
  CONTRACT {
  };
