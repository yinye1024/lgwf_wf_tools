{
  "id": "skill-packaging",
  "kind": "lgwf",
  "version": 1,
  "workflow_lgwf": "workflows/skill-packaging/wf/workflow.lgwf",
  "work_dir": "workflows/skill-packaging/ws",
  "input_mode": "input_json_required",
  "input_schema": {
    "type": "object",
    "required": ["packaging_request"],
    "properties": {
      "packaging_request": {
        "type": "object",
        "required": ["source_skill", "output_parent"],
        "properties": {
          "source_skill": {
            "type": "string"
          },
          "output_parent": {
            "type": "string"
          },
          "runtime_source": {
            "type": "string"
          },
          "force": {
            "type": "boolean"
          },
          "audit_smoke": {
            "type": "boolean"
          }
        }
      }
    },
    "example": {
      "packaging_request": {
        "source_skill": "skills/example-skill",
        "output_parent": "dist",
        "runtime_source": "skills/lgwf-wf-tools/vendor/lgwf-client-assist",
        "force": false,
        "audit_smoke": true
      }
    }
  },
  "input_file_policy": "Use UTF-8 no BOM --input-json-file when source_skill or output_parent contains Chinese or spaces.",
  "auto_human_policy": "conditional",
  "target_scope": {
    "fields": [
      "packaging_request.source_skill",
      "packaging_request.output_parent",
      "packaging_request.runtime_source"
    ],
    "write_scope": "Writes only the approved packaged skill output directory under output_parent."
  },
  "state_boundary": {
    "work_dir": "workflows/skill-packaging/ws",
    "runtime_state": ".lgwf/",
    "target_writes": "approved packaged skill output only"
  },
  "outputs": {
    "summary": ".lgwf/packaging_result_summary.json",
    "handoff": "",
    "reports": [
      "reports/skill-packaging/packaging_result_report.md"
    ]
  },
  "resume_policy": "Reuse the same work_dir when a pending review or partial packaging result already exists."
}
