WORKFLOW lgwf_plan;
ENTRY generate_plan;

DEFAULTS {
  ref_root workflow ".";
  timeout_seconds 900;
  result_path "lgwf_plan.results.{node}";
}

STEP generate_plan
  WORKFLOW "01_generate_plan/workflow.lgwf"
  CONTRACT {
    WRITE workspace file ".lgwf/react_task_plan_observe.json";
    WRITE workspace file ".lgwf/react_task_plan_proposal.json";
    WRITE workspace file ".lgwf/react_task_request.json";
    WRITE workspace file ".lgwf/react_task_request_finish.json";
  };

STEP generate_acceptance
  WORKFLOW "02_generate_acceptance/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/react_task_plan_observe.json";
    READ workspace file ".lgwf/react_task_plan_proposal.json";
    READ workspace file ".lgwf/react_task_request.json";
    WRITE workspace file ".lgwf/react_acceptance_generation_direction.json";
    WRITE workspace file ".lgwf/react_acceptance_proposal.json";
    WRITE state.lgwf_plan.confirmation_context;
  };

REVIEW confirm_plan_and_acceptance
  PROMPT_REF "03_confirm_plan_and_acceptance/00_user_decision_template/plan_acceptance_decision_template.md"
  CONTEXT state.lgwf_plan.confirmation_context
  RESULT state.lgwf_plan.contract_approval_result
  PERSIST ".lgwf/react_task_contract_approval.json"
  OPTIONS ["approve", "revise", "reject"]
  CONTRACT {
    WRITE workspace file ".lgwf/react_task_contract_approval.json";
    READ state.lgwf_plan.confirmation_context;
  };

PY apply_confirmed_contracts
  SCRIPT "03_confirm_plan_and_acceptance/01_apply_confirmed_contracts/scripts/apply_confirmed_contracts.py"
  TIMEOUT 60
  RESULT state.lgwf_plan.apply_contracts_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/react_acceptance_proposal.json";
    READ workspace file ".lgwf/react_task_contract_approval.json";
    READ workspace file ".lgwf/react_task_plan_proposal.json";
    READ workspace file ".lgwf/react_task_request.json";
    WRITE workspace file ".lgwf/react_acceptance_plan.json";
    WRITE workspace file ".lgwf/react_task_plan.json";
  };

PY finish_contract_review
  SCRIPT "03_confirm_plan_and_acceptance/01_apply_confirmed_contracts/scripts/finish_contract_review.py"
  TIMEOUT 60
  RESULT state.lgwf_plan.contract_review_finish_result
  UPDATES_STATE
  CONTRACT {
    READ workspace file ".lgwf/react_task_contract_approval.json";
    WRITE workspace file ".lgwf/contract_review_finish.json";
  };

STEP execute_react_loop
  WORKFLOW "04_execute_react_loop/workflow.lgwf"
  CONTRACT {
    READ workspace file ".lgwf/react_acceptance_plan.json";
    READ workspace file ".lgwf/react_task_plan.json";
  };

FLOW {
  generate_plan THEN generate_acceptance THEN confirm_plan_and_acceptance;

  confirm_plan_and_acceptance
    WHEN "approve" THEN finish_contract_review
    WHEN "revise" THEN confirm_plan_and_acceptance
    WHEN "reject" THEN FAIL_ALL;

  finish_contract_review THEN apply_confirmed_contracts;
  apply_confirmed_contracts THEN execute_react_loop;
}

