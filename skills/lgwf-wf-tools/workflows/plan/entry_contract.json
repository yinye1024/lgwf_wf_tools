{
  "id": "plan",
  "kind": "lgwf",
  "version": 1,
  "workflow_lgwf": "workflows/plan/wf/workflow.lgwf",
  "work_dir": "workflows/plan/ws",
  "input_mode": "input_json_required",
  "input_schema": {
    "type": "object",
    "required": ["react_task_request"],
    "properties": {
      "react_task_request": {
        "type": "object",
        "required": ["objective", "request", "target_type"],
        "properties": {
          "objective": {"type": "string"},
          "request": {"type": "string"},
          "target_type": {
            "type": "string",
            "enum": ["create_artifact", "modify_artifact", "execute_process", "analyze", "fix", "review"]
          },
          "analysis_target_files": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "analysis_target_dirs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "constraints": {"type": "array"}
        },
        "anyOf": [
          {"required": ["analysis_target_files"]},
          {"required": ["analysis_target_dirs"]}
        ]
      }
    },
    "example": {
      "react_task_request": {
        "objective": "要完成的复杂任务目标",
        "request": "用户原始请求、执行范围和交付口径",
        "target_type": "modify_artifact",
        "analysis_target_files": ["D:/example/path/to/file.md"],
        "constraints": ["先生成计划和验收契约，用户确认后再修改目标文件"]
      }
    }
  },
  "input_file_policy": "Use UTF-8 no BOM --input-json-file for react_task_request.",
  "auto_human_policy": "forbidden",
  "target_scope": {
    "fields": ["react_task_request.analysis_target_files", "react_task_request.analysis_target_dirs"],
    "write_scope": "Only after explicit plan and acceptance confirmation."
  },
  "state_boundary": {
    "work_dir": "workflows/plan/ws",
    "runtime_state": ".lgwf/",
    "target_writes": "confirmed execution scope only"
  },
  "outputs": {
    "summary": ".lgwf/plan_result_summary.json",
    "handoff": "",
    "reports": []
  },
  "resume_policy": "Use the facade continue/resume/rerun flow for the fixed work_dir."
}
